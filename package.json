{
  "name": "designer-toolbox",
  "version": "0.1.0",
  "description": "設計師工具箱：多個純前端微型工具，共用一套設計系統",
  "private": true,
  "scripts": {
    "compile:css": "sass shared/styles/shared.scss:shared/styles/shared.css index.scss:index.css services/social-size/style.scss:services/social-size/style.css services/device-size/style.scss:services/device-size/style.css services/image-compress/style.scss:services/image-compress/style.css services/svg-to-font/style.scss:services/svg-to-font/style.css services/grid-flex/style.scss:services/grid-flex/style.css services/image-crop/style.scss:services/image-crop/style.css services/favicon/style.scss:services/favicon/style.css services/qr-code/style.scss:services/qr-code/style.css services/color-palette/style.scss:services/color-palette/style.css services/color-convert/style.scss:services/color-convert/style.css services/type-scale/style.scss:services/type-scale/style.css services/lorem/style.scss:services/lorem/style.css services/word-count/style.scss:services/word-count/style.css services/shadow/style.scss:services/shadow/style.css services/gradient/style.scss:services/gradient/style.css services/image-convert/style.scss:services/image-convert/style.css services/decision-spinner/style.scss:services/decision-spinner/style.css services/fake-update/style.scss:services/fake-update/style.css services/message-board/style.scss:services/message-board/style.css services/pdf-compress/style.scss:services/pdf-compress/style.css services/pomodoro/style.scss:services/pomodoro/style.css services/watermark/style.scss:services/watermark/style.css services/unit-convert/style.scss:services/unit-convert/style.css services/text-case/style.scss:services/text-case/style.css services/amount-words/style.scss:services/amount-words/style.css services/video-compress/style.scss:services/video-compress/style.css services/pangu/style.scss:services/pangu/style.css services/contrast-checker/style.scss:services/contrast-checker/style.css services/cubic-bezier/style.scss:services/cubic-bezier/style.css services/clamp-calc/style.scss:services/clamp-calc/style.css services/color-extractor/style.scss:services/color-extractor/style.css services/paper-size/style.scss:services/paper-size/style.css --no-source-map",
    "stamp": "node stamp-version.js",
    "build:css": "npm run compile:css && npm run stamp",
    "watch:css": "npm run compile:css -- --watch",
    "dev": "npm run watch:css"
  },
  "devDependencies": {
    "sass": "^1.101.0"
  },
  "dependencies": {
    "mediabunny": "^1.46.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227"
  }
}
